---
import { nav } from '../data/site';
import Icon from './Icon.astro';
interface Props { active?: string; }
const { active = 'home' } = Astro.props;
---

<header class="topbar">
  <button class="mobile-menu icon-button" type="button" aria-label="打开菜单" data-menu-button>
    <Icon name="menu" size={24} />
  </button>
  <nav aria-label="主导航">
    {nav.map((item) => (
      <a href={item.href} class:list={{ active: active === item.key }}>{item.label}</a>
    ))}
  </nav>
  <div class="topbar__right">
    <button class="search-button icon-button" type="button" aria-label="搜索收藏" data-search-open><Icon name="search" size={24} /></button>
  </div>
</header>

<style>
  .topbar { height: 84px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--line); margin-bottom: 18px; }
  nav { display: flex; height: 100%; align-items: stretch; gap: clamp(28px, 5vw, 72px); }
  nav a { position: relative; display: flex; align-items: center; justify-content: center; color: var(--ink); font-size: 15px; line-height: 1; }
  nav a::after { content: ''; position: absolute; left: 50%; bottom: 15px; width: 0; height: 2px; background: var(--accent); transform: translateX(-50%); transition: width .2s ease; }
  nav a:hover::after, nav a.active::after { width: 100%; }
  .topbar__right { display: flex; align-items: center; justify-content: flex-end; margin-left: auto; }
  .icon-button { border: 0; background: transparent; cursor: pointer; color: var(--ink); }
  .search-button { width: 32px; height: 32px; display: grid; place-items: center; padding: 3px; }
  .mobile-menu { display: none; width: 34px; padding: 5px; }
  @media (max-width: 820px) {
    .topbar { height: 64px; margin-bottom: 12px; }
    nav { display: none; }
    .mobile-menu { display: block; }
  }
</style>
