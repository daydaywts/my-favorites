---
import Layout from '../layouts/Layout.astro';
import FilterBar from './FilterBar.astro';
import MediaCard from './MediaCard.astro';
import type { Category, LibraryItem } from '../types';

interface Props {
  title: string;
  intro: string;
  category: Category;
  items: LibraryItem[];
}
const { title, intro, category, items } = Astro.props;
const categoryNames = { movie: '影视', manga: '漫画', game: '游戏' };
const availableTags = [...new Set(items.flatMap((item) => item.tags))].sort((a, b) => a.localeCompare(b, 'zh-CN'));
const desktopColumns = Math.min(items.length, 7);
---

<Layout title={title} description={intro} active={category}>
  <section class="collection-head">
    <div class="collection-head__copy">
      <h1>{title}</h1>
      <p>{intro}</p>
    </div>
  </section>
  <div class="collection-tools"><FilterBar tags={availableTags} showAnimeToggle={category === 'movie'} /></div>
  <div class="collection-summary">
    <span>共 {items.length} 部{categoryNames[category]}</span>
  </div>
  <section class="collection-grid" style={`--desktop-columns:${desktopColumns}`} data-library-grid>
    {items.map((item) => <MediaCard item={item} />)}
  </section>
  <div class="empty-state" data-empty-state>没有找到符合条件的作品。</div>
</Layout>

<style>
  .collection-head { display: flex; width: 100%; align-items: flex-end; justify-content: space-between; gap: 30px; padding: 26px 0 30px; border-bottom: 1px solid var(--line); }
  .collection-head__copy { min-width: 0; }
  .collection-head h1 { margin: 0 0 9px; font-size: 34px; font-weight: 600; }
  .collection-head p { margin: 0; color: var(--muted); line-height: 1.8; }
  .collection-tools { width: 100%; padding-top: 20px; }
  .collection-summary { display: flex; justify-content: space-between; color: var(--muted); font-size: 11px; margin: 2px 0 12px; }
  .collection-grid { display: grid; width: 100%; grid-template-columns: repeat(var(--desktop-columns), minmax(0, 159px)); justify-content: space-between; gap: 16px; }
  @media (max-width: 1500px) { .collection-grid { grid-template-columns: repeat(6, minmax(0, 159px)); } }
  @media (max-width: 1280px) { .collection-grid { grid-template-columns: repeat(5, minmax(0, 159px)); } }
  @media (max-width: 1100px) { .collection-grid { grid-template-columns: repeat(4, minmax(0, 159px)); } }
  @media (max-width: 880px) { .collection-grid { grid-template-columns: repeat(3, minmax(0, 159px)); } }
  @media (max-width: 520px) { .collection-grid { grid-template-columns: repeat(2, minmax(0, 159px)); gap: 14px; } }
</style>
