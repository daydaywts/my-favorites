---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'articles'>; }
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.summary} active="notes">
  <article class="article-page">
    <a class="back" href="notes">← 返回全部文章</a>
    <header>
      <p>{entry.data.date}　·　{entry.data.tags.join(' / ')}</p>
      <h1>{entry.data.title}</h1>
      <span>{entry.data.summary}</span>
    </header>
    <div class="article-body">
      <Content />
    </div>
    <footer>
      <div>{entry.data.tags.map((tag: string) => <span>#{tag}</span>)}</div>
      <a href="notes">继续阅读其他文章　→</a>
    </footer>
  </article>
</Layout>

<style>
  .article-page { width: min(100%, 850px); margin: 0 auto; padding: 20px 0 60px; }
  .back { display: inline-block; margin-bottom: 32px; color: var(--muted); font-size: 11px; }
  header { padding-bottom: 30px; border-bottom: 1px solid var(--line); }
  header p { margin: 0 0 13px; color: var(--muted); font-size: 11px; }
  h1 { margin: 0 0 15px; font-size: clamp(31px, 5vw, 48px); line-height: 1.3; font-weight: 650; }
  header span { color: var(--ink-soft); font-size: 16px; line-height: 1.8; }
  .article-body { padding: 28px 0; color: var(--ink-soft); }
  .article-body :global(p) { margin: 0 0 1.45em; font-size: 16px; line-height: 2; }
  .article-body :global(h2) { margin: 1.8em 0 .7em; color: var(--ink); font-size: 23px; font-weight: 600; }
  .article-body :global(h3) { margin: 1.5em 0 .6em; color: var(--ink); font-size: 18px; font-weight: 600; }
  .article-body :global(ul), .article-body :global(ol) { margin: 0 0 1.5em; padding-left: 1.5em; font-size: 15px; line-height: 2; }
  .article-body :global(blockquote) { margin: 1.7em 0; padding: 17px 21px; border-left: 3px solid var(--ink); background: var(--soft); color: var(--ink-soft); }
  .article-body :global(blockquote p) { margin: 0; }
  .article-body :global(a) { color: var(--ink); text-decoration: underline; text-underline-offset: 3px; }
  .article-body :global(img) { display: block; max-width: 100%; height: auto; margin: 1.7em auto; }
  .article-body :global(code) { padding: 2px 5px; background: var(--soft); font-size: .9em; }
  footer { display: flex; justify-content: space-between; gap: 20px; padding-top: 22px; border-top: 1px solid var(--line); }
  footer div { display: flex; flex-wrap: wrap; gap: 7px; }
  footer a, footer span { color: var(--muted); font-size: 11px; }
</style>
