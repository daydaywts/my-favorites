---
import Layout from '../layouts/Layout.astro';
---
<Layout title="页面未找到">
  <section class="not-found">
    <span>404</span>
    <h1>这一页还没有被收藏</h1>
    <p>链接可能已改变，或者作品还没有加入收藏库。</p>
    <a href="./">返回首页</a>
  </section>
</Layout>
<style>
  .not-found { min-height: 65vh; display: grid; place-content: center; text-align: center; }
  .not-found span { font: 80px var(--font-sans); color: var(--line-strong); }
  h1 { font-weight: 500; }
  p { color: var(--muted); }
  a { justify-self: center; margin-top: 15px; padding: 9px 22px; border: 1px solid var(--ink); border-radius: 30px; color: var(--ink); }
</style>
